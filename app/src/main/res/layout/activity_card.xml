<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/download__3_"
    tools:context=".Card">

    <Button
        android:id="@+id/helpBtn"
        android:layout_width="56dp"
        android:layout_height="49dp"
        android:layout_marginStart="336dp"
        android:layout_marginTop="28dp"
        android:background="@android:drawable/ic_menu_help"
        android:backgroundTint="#FDFBFB"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="SpeakableTextPresentCheck" />

    <TextView
        android:id="@+id/help"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="28dp"
        android:fontFamily="@font/advent_pro_bold"
        android:text="Help"
        android:textColor="#FAF6F6"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/helpBtn" />

    <TextView
        android:id="@+id/cheertext1"
        android:layout_width="279dp"
        android:layout_height="48dp"
        android:layout_marginStart="154dp"
        android:layout_marginTop="128dp"
        android:layout_marginEnd="200dp"
        android:fontFamily="@font/aldrich"
        android:textColor="#42F407"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.433"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/cheertext2"
        android:layout_width="282dp"
        android:layout_height="48dp"
        android:layout_marginStart="154dp"
        android:layout_marginTop="176dp"
        android:layout_marginEnd="200dp"
        android:fontFamily="@font/aldrich"
        android:textColor="#F00808"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.44"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/hackBtn"
        android:layout_width="83dp"
        android:layout_height="86dp"
        android:layout_marginEnd="60dp"
        android:layout_marginBottom="152dp"
        android:backgroundTint="#0AC111"
        android:text="O"
        android:textAlignment="center"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/mythBtn"
        android:layout_width="83dp"
        android:layout_height="86dp"
        android:layout_marginStart="60dp"
        android:layout_marginBottom="156dp"
        android:backgroundTint="#F00C1C"
        android:text="X"
        android:textAlignment="center"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/myth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="68dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/aldrich"
        android:text="MYTH"
        android:textColor="#FAF6F6"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mythBtn" />

    <TextView
        android:id="@+id/hack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="76dp"
        android:fontFamily="@font/aldrich"
        android:text="HACK"
        android:textColor="#FAF6F6"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/hackBtn" />

    <Button
        android:id="@+id/scoreBtn"
        android:layout_width="127dp"
        android:layout_height="50dp"
        android:layout_marginEnd="56dp"
        android:layout_marginBottom="39dp"
        android:backgroundTint="#17B4FB"
        android:fontFamily="@font/aldrich"
        android:text="score"
        android:textColor="#070707"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/flashCard"
        android:layout_width="346dp"
        android:layout_height="104dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="19dp"
        android:layout_marginBottom="360dp"
        android:fontFamily="@font/aldrich"
        android:textColor="#F8F5F5"
        android:textSize="30sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cheertext2" />

    <Button
        android:id="@+id/nextBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="156dp"
        android:layout_marginBottom="260dp"
        android:backgroundTint="#17B4FB"
        android:fontFamily="@font/aldrich"
        android:text="Next"
        android:textColor="#0F0E0E"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>